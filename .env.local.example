# =============================================================================
# Aplicación Next.js
# URL canónica de esta app (callbacks y logout de Auth0 deben coincidir).
# =============================================================================
APP_BASE_URL=http://localhost:3000

# =============================================================================
# Backend FastAPI (PetMind)
# URL base del API hacia el que el BFF reenvía (/api/petmind/... en el servidor).
# NEXT_PUBLIC_API_BASE_URL tiene prioridad; NEXT_PUBLIC_API_URL es alias por compatibilidad.
# =============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# Auth0 — identidad pública (NEXT_PUBLIC_*; expuesto al navegador)
# Dominio del tenant, Client ID de aplicación Regular Web, audience del API backend.
# =============================================================================
NEXT_PUBLIC_AUTH0_DOMAIN=dev-xxx.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=https://api.petmind.example

# =============================================================================
# Auth0 — RBAC / Actions (opcional)
# Claim del ID token donde vienen roles. Por defecto en código: https://petmind.ai/roles
# =============================================================================
# NEXT_PUBLIC_AUTH0_ROLES_CLAIM=https://petmind.ai/roles

# =============================================================================
# Auth0 — solo servidor (nunca uses NEXT_PUBLIC_ en secretos)
# Client secret del dashboard; AUTH0_SECRET cifra cookies de sesión (openssl rand -hex 32).
# =============================================================================
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=

# =============================================================================
# Auth0 — parámetros OIDC (opcional)
# Por defecto en código: openid profile email offline_access
# =============================================================================
# AUTH0_SCOPE=openid profile email offline_access

# =============================================================================
# Auth0 — alternativa sin prefijo público (opcional)
# Si no defines NEXT_PUBLIC_AUTH0_DOMAIN / NEXT_PUBLIC_AUTH0_CLIENT_ID, el SDK en
# servidor puede usar AUTH0_DOMAIN y AUTH0_CLIENT_ID (ver lib/auth0.ts).
# =============================================================================
# AUTH0_DOMAIN=dev-xxx.us.auth0.com
# AUTH0_CLIENT_ID=
